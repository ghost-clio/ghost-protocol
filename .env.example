# Ghost Protocol — Environment Variables
# Copy to .env and fill in your values

# Venice.ai API (private reasoning — zero data retention)
VENICE_API_KEY=

# Uniswap Developer Platform
UNISWAP_API_KEY=

# Base RPC
BASE_RPC_URL=https://mainnet.base.org

# Agent wallet (Base chain) — NEVER commit this
AGENT_WALLET_KEY=

# Agent config
DRY_RUN=true
INTERVAL_MS=300000
MAX_CYCLES=3
TOKENS=ETH,USDC,DAI
